{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": ".venv/Scripts/python.exe",
      "runtimeArgs": ["-m", "uvicorn", "web.backend.server:app", "--reload", "--port", "8000"],
      "port": 8000
    },
    {
      "name": "frontend",
      "runtimeExecutable": "node",
      "runtimeArgs": ["web/frontend/node_modules/vite/bin/vite.js", "--config", "web/frontend/vite.config.ts", "--port", "5173"],
      "port": 5173
    }
  ]
}
